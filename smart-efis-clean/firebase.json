{
  "hosting": [
    {
      "target": "en",
      "public": "public/en",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "**/storage/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "ar",
      "public": "public/ar",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "**/storage/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
